# ===========================
# Root level .gitignore
# ===========================

# Environment files — NEVER commit these
.env
.env.local
.env.production
.env.development
.env*.local
backend/.env
frontend/.env*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
logs/

# Docker
docker_err.txt
docker_err_ascii.txt

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Node
node_modules/
.npm/

# Next.js
frontend/.next/
frontend/out/
frontend/.vercel/
frontend/build/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
